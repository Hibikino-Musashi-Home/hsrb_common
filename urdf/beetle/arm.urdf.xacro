<robot xmlns:xacro="http://ros.org/wiki/xacro">

  <!-- arm -->
  <xacro:macro name="hsr_beetle_arm" params="name parent *origin">
    <joint name="${name}_lift_joint" type="prismatic">
      <insert_block name="origin" />
      <axis xyz="0.0 0.0 1.0" />
      <limit effort="100.0" velocity="0.2" lower="0.0" upper="0.69" />
      <parent link="${parent}" />
      <child link="${name}_lift_link" />
    </joint>

    <link name="${name}_lift_link">
      <inertial>
        <mass value="1.275819"/>
        <origin xyz="0.051549 0.042438 -0.064145"/>
        <inertia ixx="0.004633" ixy="0.000475272668" ixz="-0.002403"
                 iyy="0.008065" iyz="-0.000100268629" izz="0.007672"/>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="package://tmc_hsrb_description/meshes/beetle/visual/shoulder.dae" />
        </geometry>
        <material name="body_sub" />
      </visual>

      <collision>
        <geometry>
          <mesh filename="package://tmc_hsrb_description/meshes/beetle/collision/shoulder.stl" />
        </geometry>
        <material name="body_sub" />
      </collision>
    </link>

    <joint name="${name}_flex_joint" type="revolute">
      <origin xyz="0.141 0.078 0.0" rpy="0.0 0.0 0.0" />
      <axis xyz="0.0 -1.0 0.0" />
      <limit effort="100.0" velocity="1.2" lower="-2.62" upper="0.0" />
      <parent link="${name}_lift_link" />
      <child link="${name}_flex_link" />
    </joint>

    <link name="${name}_flex_link">
      <inertial>
        <mass value="1.339295"/>
        <origin xyz="0.000632 0.006404 0.118529"/>
        <inertia ixx="7.528" ixy="-0.000020284207" ixz="-0.000022947194"
                 iyy="0.007102" iyz="-0.000091796075" izz="0.001552"/>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="package://tmc_hsrb_description/meshes/beetle/visual/arm_flex.dae" />
        </geometry>
        <material name="body_main" />
      </visual>

      <collision>
        <geometry>
          <mesh filename="package://tmc_hsrb_description/meshes/beetle/collision/arm_flex.stl" />
        </geometry>
        <material name="body_main" />
      </collision>
    </link>

    <joint name="${name}_roll_joint" type="revolute">
      <origin xyz="0.005 0.0 0.345" rpy="0.0 0.0 0.0" />
      <axis xyz="0.0 0.0 1.0" />
      <limit effort="100.0" velocity="2.0" lower="-2.09" upper="3.84" />
      <parent link="${name}_flex_link" />
      <child link="${name}_roll_link" />
    </joint>

    <link name="${name}_roll_link">
      <inertial>
        <mass value="0.247936"/>
        <origin xyz="-0.006927 0.002039 -0.064837"/>
        <inertia ixx="0.004267" ixy="-0.000018322199" ixz="0.000017984455"
                 iyy="0.000780923828" iyz="-0.00001392334" izz="0.00412"/>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="package://tmc_hsrb_description/meshes/beetle/visual/arm_roll.dae" />
        </geometry>
        <material name="body_main" />
      </visual>

      <collision>
        <geometry>
          <mesh filename="package://tmc_hsrb_description/meshes/beetle/collision/arm_roll.stl" />
        </geometry>
        <material name="body_main" />
      </collision>
    </link>
  </xacro:macro>
</robot>
