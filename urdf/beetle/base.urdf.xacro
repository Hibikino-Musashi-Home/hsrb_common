<robot xmlns:xacro="http://ros.org/wiki/xacro">

  <!-- constant -->
  <property name="drive_wheel_width" value="0.03" />
  <property name="drive_wheel_radius" value="0.040" />

  <property name="drive_wheel_offset_x" value="-0.073" />
  <property name="drive_wheel_offset_y" value="0.1275" />

  <property name="passive_wheel_radius" value="0.03" />

  <property name="passive_wheel_offset_x" value="0.145" />
  <property name="passive_wheel_offset_y" value="0.04" />


  <!-- drive wheel -->
  <xacro:macro name="hsr_beetle_drive_wheel" params="prefix parent *origin">
    <joint name="${prefix}_drive_wheel_joint" type="continuous">
      <insert_block name="origin" />
      <axis xyz="0.0 1.0 0.0" />
      <limit effort="100.0" velocity="10.0" />
      <parent link="${parent}" />
      <child link="${prefix}_drive_wheel_link" />
    </joint>

    <link name="${prefix}_drive_wheel_link">
      <visual>
        <origin xyz="0.0 0.0 0.0" rpy="${pi/2} 0.0 0.0"/>
        <geometry>
          <cylinder radius="${drive_wheel_radius}" length="${drive_wheel_width}" />
        </geometry>
        <material name="wheel" />
      </visual>
      <collision>
        <origin xyz="0.0 0.0 0.0" rpy="${pi/2} 0.0 0.0"/>
        <geometry>
          <cylinder radius="${drive_wheel_radius}" length="${drive_wheel_width}" />
        </geometry>
        <material name="wheel" />
      </collision>
      <inertial>
        <mass value="1"/>
        <origin xyz="0 0 0"/>
        <inertia ixx="1" ixy="0" ixz="0" iyy="1" iyz="0" izz="1"/>
      </inertial>
    </link>
  </xacro:macro>


  <!-- passive wheel -->
  <xacro:macro name="hsr_beetle_passive_wheel" params="prefix parent *origin">
    <joint name="${prefix}_passive_wheel_x_joint" type="continuous">
      <insert_block name="origin" />
      <axis xyz="1.0 0.0 0.0" />
      <limit effort="1000.0" velocity="100.0" />
      <parent link="${parent}" />
      <child link="${prefix}_passive_wheel_x_frame" />
    </joint>

    <link name="${prefix}_passive_wheel_x_frame">
      <inertial>
        <mass value="0.3"/>
        <origin xyz="0 0 0"/>
        <inertia ixx="1" ixy="0" ixz="0" iyy="1" iyz="0" izz="1"/>
      </inertial>
    </link>

    <joint name="${prefix}_passive_wheel_y_joint" type="continuous">
      <axis xyz="0.0 1.0 0.0" />
      <limit effort="1000.0" velocity="100.0" />
      <parent link="${prefix}_passive_wheel_x_frame" />
      <child link="${prefix}_passive_wheel_y_frame" />
    </joint>

    <link name="${prefix}_passive_wheel_y_frame">
      <inertial>
        <mass value="0.3"/>
        <origin xyz="0 0 0"/>
        <inertia ixx="1" ixy="0" ixz="0" iyy="1" iyz="0" izz="1"/>
      </inertial>
    </link>

    <joint name="${prefix}_passive_wheel_z_joint" type="continuous">
      <axis xyz="0.0 0.0 1.0" />
      <limit effort="1000.0" velocity="100.0" />
      <parent link="${prefix}_passive_wheel_y_frame" />
      <child link="${prefix}_passive_wheel_z_link" />
    </joint>

    <link name="${prefix}_passive_wheel_z_link">
      <visual>
        <geometry>
          <sphere radius="${passive_wheel_radius}" />
        </geometry>
        <material name="wheel" />
      </visual>
      <collision>
        <geometry>
          <sphere radius="${passive_wheel_radius}" />
        </geometry>
        <material name="wheel" />
      </collision>
      <inertial>
        <mass value="0.3"/>
        <origin xyz="0 0 0"/>
        <inertia ixx="1" ixy="0" ixz="0" iyy="1" iyz="0" izz="1"/>
      </inertial>
    </link>
  </xacro:macro>


  <!-- base -->
  <xacro:macro name="hsr_beetle_base" params="name">
    <link name="${name}_link">
      <visual>
        <geometry>
          <mesh filename="package://tmc_hsrb_description/meshes/beetle/visual/base.dae" />
        </geometry>
        <material name="body_main" />
      </visual>
      <visual>
        <geometry>
          <mesh filename="package://tmc_hsrb_description/meshes/beetle/visual/body.dae" />
        </geometry>
        <material name="body_main" />
      </visual>
      <visual>
        <geometry>
          <mesh filename="package://tmc_hsrb_description/meshes/beetle/visual/torso_base.dae" />
        </geometry>
        <material name="body_sub" />
      </visual>

      <collision>
        <geometry>
          <mesh filename="package://tmc_hsrb_description/meshes/beetle/collision/base.stl" />
        </geometry>
        <material name="body_sub" />
      </collision>
    </link>

    <joint name="${name}_body_joint" type="fixed">
      <parent link="${name}_link" />
      <child link="${name}_body_link" />
    </joint>

    <link name="${name}_body_link">
      <inertial>
        <mass value="11.017971"/>
        <origin xyz="-0.025978 -0.005498 0.17633"/>
        <inertia ixx="0.3742" ixy="0.000434172172" ixz="0.03088"
                 iyy="0.3436" iyz="0.01775" izz="0.1509"/>
      </inertial>
    </link>

    <joint name="${name}_roll_joint" type="continuous">
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0" />
      <axis xyz="0.0 0.0 1.0" />
      <limit effort="100.0" velocity="1.0" />
      <parent link="${name}_body_link" />
      <child link="${name}_roll_link" />
      <limit effort="1.0" velocity="1.0"/>
    </joint>

    <link name="${name}_roll_link">
      <inertial>
        <origin xyz="-0.01948200 0.00219100 0.07101300" />
        <mass value="10.239419"/>
        <inertia ixx="0.07671000"  ixy="-0.01005000"  ixz="0.00174900"
                 iyy="0.09057000" iyz="0.00154900" izz="0.14500000" />
      </inertial>
    </link>


    <!-- wheels -->
    <xacro:hsr_beetle_drive_wheel prefix="${robot_name}right" parent="${name}_roll_link">
      <origin xyz="${drive_wheel_offset_x}
                   ${-drive_wheel_offset_y}
                   ${drive_wheel_radius}"
              rpy="0.0 0.0 0.0" />
    </xacro:hsr_beetle_drive_wheel>

    <xacro:hsr_beetle_drive_wheel prefix="${robot_name}left" parent="${name}_roll_link">
      <origin xyz="${drive_wheel_offset_x}
                   ${drive_wheel_offset_y}
                   ${drive_wheel_radius}"
              rpy="0.0 0.0 0.0" />
    </xacro:hsr_beetle_drive_wheel>

    <xacro:hsr_beetle_passive_wheel prefix="${robot_name}right" parent="${name}_roll_link">
      <origin xyz="${passive_wheel_offset_x}
                   ${-passive_wheel_offset_y}
                   ${passive_wheel_radius}"
              rpy="0.0 0.0 0.0" />
    </xacro:hsr_beetle_passive_wheel>

    <xacro:hsr_beetle_passive_wheel prefix="${robot_name}left" parent="${name}_roll_link">
      <origin xyz="${passive_wheel_offset_x}
                   ${passive_wheel_offset_y}
                   ${passive_wheel_radius}"
              rpy="0.0 0.0 0.0" />
    </xacro:hsr_beetle_passive_wheel>


    <!-- sensors -->
    <xacro:range_sensor prefix="${name}" parent="${name}_link">
      <origin xyz="0.1375 0.0 0.1895" rpy="0.0 0.0 0.0" />
    </xacro:range_sensor>

    <xacro:imu_sensor prefix="${name}" parent="${name}_link">
      <origin xyz="0.0005 0.1296 0.181" rpy="${pi} 0.0 0.0" />
    </xacro:imu_sensor>
  </xacro:macro>
</robot>
