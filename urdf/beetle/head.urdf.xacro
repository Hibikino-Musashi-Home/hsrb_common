<robot xmlns:xacro="http://ros.org/wiki/xacro">

  <!-- head -->
  <xacro:macro name="hsr_beetle_head" params="name parent *origin">
    <joint name="${name}_pan_joint" type="revolute">
      <insert_block name="origin" />
      <axis xyz="0.0 0.0 1.0" />
      <limit effort="100.0" velocity="1.0" lower="-3.84" upper="2.09" />
      <parent link="${parent}" />
      <child link="${name}_pan_link" />
    </joint>

    <link name="${name}_pan_link">
      <inertial>
        <mass value="0.571903"/>
        <origin xyz="0.001724 -0.001969 -0.028886"/>
        <inertia ixx="0.0009711421" ixy="0.00006179487" ixz="-0.000113923121"
                 iyy="0.00065335493" iyz="0.000069036305" izz="0.000765202576"/>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="package://tmc_hsrb_description/meshes/beetle/visual/head_pan.dae" />
        </geometry>
        <material name="body_main" />
      </visual>

      <collision>
        <geometry>
          <mesh filename="package://tmc_hsrb_description/meshes/beetle/collision/head_pan.stl" />
        </geometry>
        <material name="body_main" />
      </collision>
    </link>

    <joint name="${name}_tilt_joint" type="revolute">
      <origin xyz="0.02 0.0 0.0" rpy="0.0 0.0 0.0" />
      <axis xyz="0.0 -1.0 0.0" />
      <limit effort="100.0" velocity="1.0" lower="-1.57" upper="0.52" />
      <parent link="${name}_pan_link" />
      <child link="${name}_tilt_link" />
    </joint>

    <link name="${name}_tilt_link">
      <inertial>
        <mass value="2.123802"/>
        <origin xyz="-0.055376 -0.002436 0.117733"/>
        <inertia ixx="0.01941" ixy="-0.000138091054" ixz="0.005035" iyy="0.01498"
                 iyz="0.000087492537" izz="0.01167"/>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="package://tmc_hsrb_description/meshes/beetle/visual/head_upper.dae" />
        </geometry>
        <material name="body_sub" />
      </visual>
      <visual>
        <geometry>
          <mesh filename="package://tmc_hsrb_description/meshes/beetle/visual/head_tilt.dae" />
        </geometry>
        <material name="body_main" />
      </visual>
      <visual>
        <geometry>
          <mesh filename="package://tmc_hsrb_description/meshes/beetle/visual/tablet_base.dae" />
        </geometry>
        <material name="body_sub" />
      </visual>
      <visual>
        <geometry>
          <mesh filename="package://tmc_hsrb_description/meshes/beetle/visual/tablet.dae" />
        </geometry>
        <material name="tablet" />
      </visual>

      <collision>
        <geometry>
          <mesh filename="package://tmc_hsrb_description/meshes/beetle/collision/head.stl" />
        </geometry>
        <material name="body_main" />
      </collision>
      <collision>
        <geometry>
          <mesh filename="package://tmc_hsrb_description/meshes/beetle/collision/tablet.stl" />
        </geometry>
        <material name="tablet" />
      </collision>
    </link>

    <!-- cameras -->
    <xacro:rgb_camera prefix="${name}_left" parent="${name}_tilt_link">
      <origin xyz="0.02 0.07 0.061" rpy="0 0 0"/>
    </xacro:rgb_camera>

    <xacro:rgb_camera prefix="${name}_right" parent="${name}_tilt_link">
      <origin xyz="0.02 -0.07 0.061" rpy="0 0 0"/>
    </xacro:rgb_camera>

    <xacro:wide_rgb_camera prefix="${name}_center" parent="${name}_tilt_link">
      <origin xyz="0.0195 0.0 0.061" rpy="0 0 0"/>
    </xacro:wide_rgb_camera>

    <xacro:xtion prefix="${name}" parent="${name}_tilt_link">
      <origin xyz="-0.079796 0.022 0.215172" rpy="0 0 0"/>
    </xacro:xtion>
  </xacro:macro>
</robot>
