<?xml version="1.0" ?>
<robot xmlns:xacro="http://ros.org/wiki/xacro">
    <xacro:include filename="$(find hsrb_parts_description)/urdf/sensors/hokuyo_laser.gazebo.xacro"/>

    <xacro:arg name="ignition_gazebo_sim" default="false" />

    <!-- range sensor -->
    <xacro:macro name="hokuyo_laser" params="prefix robot_namespace parent min_angle max_angle ros_topic:='scan' *origin">
        <joint name="${prefix}_range_sensor_joint" type="fixed">
            <xacro:insert_block name="origin" />
            <parent link="${parent}" />
            <child link="${prefix}_range_sensor_link" />
        </joint>

        <link name="${prefix}_range_sensor_link">
            <visual>
                <geometry>
                    <mesh filename="package://hsrb_parts_description/meshes/sensors/laser.dae" />
                </geometry>
            </visual>

            <collision>
                <geometry>
                    <mesh filename="package://hsrb_parts_description/meshes/sensors/laser.stl" />
                </geometry>
            </collision>
            <inertial>
                <origin xyz="0 0 0"/>
                <mass value="0.01"/>
                <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
            </inertial>
        </link>

        <xacro:if value="$(arg ignition_gazebo_sim)">
            <xacro:hokuyo_laser_gazebo_ignition
                sensor_name="${prefix}_range_sensor"
                robot_namespace="${robot_namespace}"
                ros_topic="${ros_topic}"
                frame_name="${prefix}_range_sensor_link"
                min_angle="${min_angle}" max_angle="${max_angle}" />
        </xacro:if>
        <xacro:unless value="$(arg ignition_gazebo_sim)">
            <xacro:hokuyo_laser_gazebo
                sensor_name="${prefix}_range_sensor"
                robot_namespace="${robot_namespace}"
                ros_topic="${ros_topic}"
                frame_name="${prefix}_range_sensor_link"
                min_angle="${min_angle}" max_angle="${max_angle}" />
        </xacro:unless>
    </xacro:macro>

</robot>
