<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro">
    <xacro:property name="palm_to_proximal_x" value="-0.01675" />
    <xacro:property name="palm_to_proximal_y" value="-0.0245" />
    <xacro:property name="palm_to_proximal_z" value="-0.0175" />

    <xacro:include filename="$(find tmc_hsrb_description)/urdf/hand_v0/hand.transmission.xacro"/>
    <xacro:include filename="$(find tmc_hsrb_description)/urdf/hand_v0/hand.gazebo.xacro"/>
    <xacro:include filename="$(find tmc_hsrb_description)/urdf/sensors/rgb_camera.urdf.xacro"/>

    <!-- constant -->
    <xacro:property name="base_joint_angle_range_min" value="-0.1" />
    <xacro:property name="base_joint_angle_range_max" value="1.24" />


    <!-- hand base -->
    <xacro:macro name="hsrb_hand_base" params="name parent *origin">
        <joint name="${name}_palm_joint" type="revolute">
            <insert_block name="origin" />
            <axis xyz="1.0 0.0 0.0" />
            <limit effort="0.0" velocity="0.0" lower="0.0" upper="0.0" />
            <parent link="${parent}" />
            <child link="${name}_palm_link" />
        </joint>

        <link name="${name}_palm_link">
            <visual>
                <geometry>
                    <mesh filename="package://tmc_hsrb_description/meshes/hand_v0/palm.dae" />
                </geometry>
                <material name="body_sub" />
            </visual>

            <collision>
                <geometry>
                    <mesh filename="package://tmc_hsrb_description/meshes/hand_v0/palm.stl" />
                </geometry>
                <material name="body_sub" />
            </collision>

            <inertial>
                <mass value="0.247936"/>
                <origin xyz="0 0 0"/>
                <inertia ixx="0.004267" ixy="-0.000018322199" ixz="0.000017984455"
                    iyy="0.000780923828" iyz="-0.00001392334" izz="0.00412"/>
            </inertial>
        </link>

        <xacro:hsrb_finger_with_vacuum name="${robot_name}/left" parent="${robot_name}/hand_palm_link">
            <origin xyz="${palm_to_proximal_x} ${palm_to_proximal_y} ${palm_to_proximal_z}"
                    rpy="0.0 0.0 0.0" />
        </xacro:hsrb_finger_with_vacuum>

        <xacro:hsrb_finger_without_vacuum name="${robot_name}/right" parent="${robot_name}/hand_palm_link">
            <origin xyz="${palm_to_proximal_x} ${-palm_to_proximal_y} ${palm_to_proximal_z}"
                    rpy="0.0 0.0 0.0" />
        </xacro:hsrb_finger_without_vacuum>

        <!-- camera -->
        <xacro:rgb_camera prefix="${name}" parent="${name}_palm_link">
            <origin xyz="0.039 0.0 -0.0045" rpy="${pi} ${-pi/2} 0"/>
        </xacro:rgb_camera>

        <xacro:hsrb_hand_gazebo robot_name="${robot_name}"/>
        <xacro:hsrb_hand_transmission robot_name="${robot_name}"/>
    </xacro:macro>


    <!-- finger with vacuum -->
    <xacro:macro name="hsrb_finger_with_vacuum" params="name parent *origin">
        <joint name="${name}_proximal_joint" type="revolute">
            <insert_block name="origin" />
            <axis xyz="1.0 0.0 0.0" />
            <limit effort="100.0" velocity="1.0"
                lower="${base_joint_angle_range_min}"
                upper="${base_joint_angle_range_max}" />
            <parent link="${parent}" />
            <child link="${name}_proximal_link" />
        </joint>

        <link name="${name}_proximal_link">
            <inertial>
                <mass value="0.043589"/>
                <origin xyz="0.021418 0.00248 0.022688"/>
                <inertia ixx="0.000026033886" ixy="-0.000000144078" ixz="-0.00000198241"
                    iyy="0.000028824811" iyz="-0.000001268421" izz="0.000005135919"/>
            </inertial>
            <visual>
                <geometry>
                    <mesh filename="package://tmc_hsrb_description/meshes/hand_v0/left_proximal.dae" />
                </geometry>
                <material name="body_sub" />
            </visual>

            <collision>
                <geometry>
                    <mesh filename="package://tmc_hsrb_description/meshes/hand_v0/left_proximal.stl" />
                </geometry>
                <material name="body_sub" />
            </collision>
        </link>

        <joint name="${name}_distal_joint" type="revolute">
            <origin xyz="0.0 0.0 0.07" rpy="0.0 0.0 0.0" />
            <axis xyz="1.0 0.0 0.0" />
            <limit effort="100.0" velocity="1.0"
                lower="${-base_joint_angle_range_max}"
                upper="${-base_joint_angle_range_min}" />
            <parent link="${name}_proximal_link" />
            <child link="${name}_distal_link" />
        </joint>

        <link name="${name}_distal_link">
            <inertial>
                <mass value="0.027731"/>
                <origin xyz="0.011116 0.005679 0.017532"/>
                <inertia ixx="0.000004451952" ixy="-0.000000617574" ixz="0.000000503765"
                    iyy="0.000000503765" iyz="-0.000000435048" izz="0.000004456764"/>
            </inertial>
            <visual>
                <geometry>
                    <mesh filename="package://tmc_hsrb_description/meshes/hand_v0/left_distal.dae" />
                </geometry>
                <material name="body_sub" />
            </visual>

            <collision>
                <geometry>
                    <mesh filename="package://tmc_hsrb_description/meshes/hand_v0/left_distal.stl" />
                </geometry>
                <material name="body_sub" />
            </collision>
        </link>

        <joint name="${name}_finger_tip_joint" type="fixed">
            <origin xyz="0.01675 0.0193 0.0379" rpy="${-pi/2.0} 0.0 0.0" />
            <parent link="${name}_distal_link" />
            <child link="${name}_finger_tip_frame" />
        </joint>

        <link name="${name}_finger_tip_frame">
        </link>

        <joint name="${name}_finger_vacuum_joint" type="fixed">
            <origin xyz="0.00475 -0.011539 0.03322" rpy="${pi/4.0} 0.0 0.0" />
            <parent link="${name}_distal_link" />
            <child link="${name}_finger_vacuum_frame" />
        </joint>

        <link name="${name}_finger_vacuum_frame">
            <visual>
                <origin xyz="0.0 0.0 -0.01" rpy="0.0 0.0 0.0" />
                <geometry>
                    <box size="0.008 0.008 0.02"/>
                </geometry>
                <material name="body_sub" />
            </visual>
        </link>
    </xacro:macro>

    <!-- finger without vacuum -->
    <xacro:macro name="hsrb_finger_without_vacuum" params="name parent *origin">
        <joint name="${name}_proximal_joint" type="revolute">
            <insert_block name="origin" />
            <axis xyz="-1.0 0.0 0.0" />
            <limit effort="100.0" velocity="1.0"
                lower="${base_joint_angle_range_min}"
                upper="${base_joint_angle_range_max}" />
            <parent link="${parent}" />
            <child link="${name}_proximal_link" />
        </joint>

        <link name="${name}_proximal_link">
            <inertial>
                <mass value="0.043956"/>
                <origin xyz="0.013203 0.002096 0.023311"/>
                <inertia ixx="0.00002623664" ixy="0.00000001631" ixz="0.000001281845"
                    iyy="0.000028838232" iyz="-0.000001621709" izz="0.000004957151"/>
            </inertial>
            <visual>
                <geometry>
                    <mesh filename="package://tmc_hsrb_description/meshes/hand_v0/right_proximal.dae" />
                </geometry>
                <material name="body_sub" />
            </visual>

            <collision>
                <geometry>
                    <mesh filename="package://tmc_hsrb_description/meshes/hand_v0/right_proximal.stl" />
                </geometry>
                <material name="body_sub" />
            </collision>
        </link>

        <joint name="${name}_distal_joint" type="revolute">
            <origin xyz="0.0 0.0 0.07" rpy="0.0 0.0 0.0" />
            <axis xyz="-1.0 0.0 0.0" />
            <limit effort="100.0" velocity="1.0"
                lower="${-base_joint_angle_range_max}"
                upper="${-base_joint_angle_range_min}" />
            <parent link="${name}_proximal_link" />
            <child link="${name}_distal_link" />
        </joint>

        <link name="${name}_distal_link">
            <inertial>
                <mass value="0.020927"/>
                <origin xyz="0.014256 -0.008321 0.015591"/>
                <inertia ixx="0.00000307518" ixy="0.000004176168" ixz="0.000002877537"
                    iyy="-0.000000049953" iyz="0.000000010237" izz="0.000000866222"/>
            </inertial>
            <visual>
                <geometry>
                    <mesh filename="package://tmc_hsrb_description/meshes/hand_v0/right_distal.dae" />
                </geometry>
                <material name="body_sub" />
            </visual>

            <collision>
                <geometry>
                    <mesh filename="package://tmc_hsrb_description/meshes/hand_v0/right_distal.stl" />
                </geometry>
                <material name="body_sub" />
            </collision>
        </link>

        <joint name="${name}_finger_tip_joint" type="fixed">
            <origin xyz="0.01675 -0.0193 0.0379" rpy="${pi/2.0} 0.0 0.0" />
            <parent link="${name}_distal_link" />
            <child link="${name}_finger_tip_frame" />
        </joint>

        <link name="${name}_finger_tip_frame"></link>
    </xacro:macro>
</robot>
