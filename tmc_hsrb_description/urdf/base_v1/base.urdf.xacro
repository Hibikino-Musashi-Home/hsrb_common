<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro">
    <xacro:include filename="$(find tmc_hsrb_description)/urdf/base_v1/base.transmission.xacro"/>
    <xacro:include filename="$(find tmc_hsrb_description)/urdf/base_v1/base.gazebo.xacro"/>
    <xacro:include filename="$(find tmc_hsrb_description)/urdf/sensors/hokuyo_laser.urdf.xacro"/>
    <xacro:include filename="$(find tmc_hsrb_description)/urdf/sensors/imu.urdf.xacro"/>

    <!-- constant -->
    <xacro:property name="drive_wheel_width" value="0.03" />
    <xacro:property name="drive_wheel_radius" value="0.040" />

    <xacro:property name="drive_wheel_offset_x" value="0.110" />
    <xacro:property name="drive_wheel_offset_y" value="0.133" />

    <xacro:property name="passive_caster_height" value="0.058" />
    <xacro:property name="passive_caster_radius" value="0.025" />
    <xacro:property name="passive_caster_width" value="0.014" />
    <xacro:property name="passive_caster_offset_x" value="0.1495" />
    <xacro:property name="passive_caster_offset_y" value="0.055" />

    <!-- drive wheel -->
    <xacro:macro name="hsrb_drive_wheel" params="prefix suffix parent *origin">
        <joint name="${prefix}_${suffix}_drive_wheel_joint" type="continuous">
            <insert_block name="origin" />
            <axis xyz="0.0 1.0 0.0" />
            <limit effort="1000.0" velocity="10.0" />
            <parent link="${parent}" />
            <child link="${prefix}_${suffix}_drive_wheel_link" />
            <dynamics damping="1.0"/>
        </joint>

        <link name="${prefix}_${suffix}_drive_wheel_link">
            <visual>
                <origin xyz="0.0 0.0 0.0" rpy="${pi/2} 0.0 0.0"/>
                <geometry>
                    <cylinder radius="${drive_wheel_radius}" length="${drive_wheel_width}" />
                </geometry>
                <material name="wheel" />
            </visual>
            <collision>
                <origin xyz="0.0 0.0 0.0" rpy="${pi/2} 0.0 0.0"/>
                <geometry>
                    <cylinder radius="${drive_wheel_radius}" length="${drive_wheel_width}" />
                </geometry>
                <material name="wheel" />
            </collision>
            <inertial>
                <mass value="0.1"/>
                <origin xyz="0 0 0"/>
                <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
            </inertial>
        </link>
    </xacro:macro>

    <!-- passive wheel -->
    <xacro:macro name="hsrb_passive_caster" params="prefix suffix parent *origin">
        <joint name="${prefix}_${suffix}_passive_caster_roll_joint" type="continuous">
            <insert_block name="origin" />
            <axis xyz="0.0 0.0 1.0" />
            <limit effort="1000.0" velocity="100.0" />
            <parent link="${parent}" />
            <child link="${prefix}_${suffix}_passive_caster_roll_link" />
            <dynamics damping="0.7"/>
        </joint>

        <link name="${prefix}_${suffix}_passive_caster_roll_link">
            <inertial>
                <mass value="0.3"/>
                <origin xyz="0 0 0"/>
                <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
            </inertial>
            <visual>
                <origin xyz="0.0 0 -0.0165"/>
                <geometry>
                    <cylinder radius="0.0085" length="0.033"/>
                </geometry>
                <material name="wheel" />
            </visual>
            <visual>
                <origin xyz="0.017 0.0 -0.033" rpy="1.57 0.0 0.0"/>
                <geometry>
                    <cylinder radius="0.02" length="0.021"/>
                </geometry>
                <material name="wheel" />
            </visual>
        </link>

        <joint name="${prefix}_${suffix}_passive_caster_left_wheel_joint" type="continuous">
            <origin xyz="0.017 0.0175 -0.033"/>
            <axis xyz="0.0 1.0 0.0" />
            <limit effort="1000.0" velocity="100.0" />
            <parent link="${prefix}_${suffix}_passive_caster_roll_link" />
            <child link="${prefix}_${suffix}_passive_caster_left_wheel_link" />
            <dynamics damping="1.0"/>
        </joint>

        <link name="${prefix}_${suffix}_passive_caster_left_wheel_link">
            <visual>
                <origin rpy="1.57 0.0 0.0"/>
                <geometry>
                    <cylinder radius="${passive_caster_radius}" length="${passive_caster_width}"/>
                </geometry>
                <material name="wheel" />
            </visual>
            <collision>
                <origin rpy="1.57 0.0 0.0"/>
                <geometry>
                    <cylinder radius="${passive_caster_radius}" length="${passive_caster_width}"/>
                </geometry>
            </collision>
            <inertial>
                <mass value="0.3"/>
                <origin xyz="0 0 0"/>
                <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
            </inertial>
        </link>

        <joint name="${prefix}_${suffix}_passive_caster_right_wheel_joint" type="continuous">
            <origin xyz="0.017 -0.0175 -0.033"/>
            <axis xyz="0.0 1.0 0.0" />
            <limit effort="1000.0" velocity="100.0" />
            <parent link="${prefix}_${suffix}_passive_caster_roll_link" />
            <child link="${prefix}_${suffix}_passive_caster_right_wheel_link" />
            <dynamics damping="1.0"/>
        </joint>

        <link name="${prefix}_${suffix}_passive_caster_right_wheel_link">
            <visual>
                <origin rpy="1.57 0.0 0.0"/>
                <geometry>
                    <cylinder radius="${passive_caster_radius}" length="${passive_caster_width}"/>
                </geometry>
                <material name="wheel" />
            </visual>
            <collision>
                <origin rpy="1.57 0.0 0.0"/>
                <geometry>
                    <cylinder radius="${passive_caster_radius}" length="${passive_caster_width}"/>
                </geometry>
                <material name="wheel" />
            </collision>
            <inertial>
                <mass value="0.3"/>
                <origin xyz="0 0 0"/>
                <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
            </inertial>
        </link>
    </xacro:macro>


    <!-- base -->
    <xacro:macro name="hsrb_base" params="prefix robot_namespace">
        <link name="base_footprint"/>

        <joint name="${prefix}_joint" type="fixed">
            <parent link="base_footprint" />
            <child link="${prefix}_link" />
        </joint>

        <link name="${prefix}_link">
            <visual>
                <geometry>
                    <mesh filename="package://tmc_hsrb_description/meshes/base_v1/base_light.dae" />
                </geometry>
                <material name="body_main" />
            </visual>
            <visual>
                <geometry>
                    <mesh filename="package://tmc_hsrb_description/meshes/base_v1/body_light.dae" />
                </geometry>
                <material name="body_main" />
            </visual>
            <visual>
                <geometry>
                    <mesh filename="package://tmc_hsrb_description/meshes/base_v1/torso_base.dae" />
                </geometry>
                <material name="body_sub" />
            </visual>

            <collision>
                <geometry>
                    <mesh filename="package://tmc_hsrb_description/meshes/base_v1/base.stl" />
                </geometry>
            </collision>
        </link>

        <joint name="${prefix}_body_joint" type="fixed">
            <parent link="${prefix}_link" />
            <child link="${prefix}_body_link" />
        </joint>

        <link name="${prefix}_body_link">
            <inertial>
                <mass value="11.017971"/>
                <origin xyz="-0.025978 -0.005498 0.17633"/>
                <inertia ixx="0.3742" ixy="0.000434172172" ixz="0.03088"
                    iyy="0.3436" iyz="0.01775" izz="0.1509"/>
            </inertial>
        </link>

        <joint name="${prefix}_roll_joint" type="continuous">
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0" />
            <axis xyz="0.0 0.0 1.0" />
            <limit effort="1000.0" velocity="1.0" />
            <parent link="${prefix}_body_link" />
            <child link="${prefix}_roll_link" />
            <dynamics damping="0.7"/>
        </joint>

        <link name="${prefix}_roll_link">
            <inertial>
                <origin xyz="-0.01948200 0.00219100 0.07101300" />
                <mass value="10.239419"/>
                <inertia
                    ixx="0.07671000"  ixy="-0.01005000"  ixz="0.00174900"
                    iyy="0.09057000" iyz="0.00154900" izz="0.14500000" />
            </inertial>
        </link>


        <!-- wheels -->
        <xacro:hsrb_drive_wheel prefix="${prefix}" suffix="right" parent="${prefix}_roll_link">
            <origin
                xyz="${-drive_wheel_offset_x} ${-drive_wheel_offset_y} ${drive_wheel_radius}"
                rpy="0.0 0.0 0.0" />
        </xacro:hsrb_drive_wheel>

        <xacro:hsrb_drive_wheel prefix="${prefix}" suffix="left" parent="${prefix}_roll_link">
            <origin
                xyz="${-drive_wheel_offset_x} ${drive_wheel_offset_y} ${drive_wheel_radius}"
                rpy="0.0 0.0 0.0" />
        </xacro:hsrb_drive_wheel>

        <xacro:hsrb_passive_caster prefix="${prefix}" suffix="right" parent="${prefix}_roll_link">
            <origin
                xyz="${passive_caster_offset_x} ${-passive_caster_offset_y} ${passive_caster_height}"
                rpy="0.0 0.0 0.0" />
        </xacro:hsrb_passive_caster>

        <xacro:hsrb_passive_caster prefix="${prefix}" suffix="left" parent="${prefix}_roll_link">
            <origin
                xyz="${passive_caster_offset_x} ${passive_caster_offset_y} ${passive_caster_height}"
                rpy="0.0 0.0 0.0" />
        </xacro:hsrb_passive_caster>


        <!-- sensors -->
        <xacro:hokuyo_laser
            prefix="${prefix}"
            robot_namespace="${robot_namespace}"
            parent="${prefix}_link">
            <origin xyz="0.1675 0.0 0.1844" rpy="0.0 0.0 0.0" />
        </xacro:hokuyo_laser>

        <xacro:imu_sensor prefix="${prefix}" robot_namespace="${robot_namespace}" parent="${prefix}_link">
            <origin xyz="0.0005 0.1296 0.181" rpy="${pi} 0.0 0.0" />
        </xacro:imu_sensor>

        <xacro:hsrb_base_gazebo prefix="${prefix}"/>
        <xacro:hsrb_base_transmission prefix="${prefix}"/>
    </xacro:macro>
</robot>
