<?xml version="1.0"?>
<robot name="hsrb"
       xmlns:controller="http://playerstage.sourceforge.net/gazebo/xmlschema/#controller"
       xmlns:interface="http://playerstage.sourceforge.net/gazebo/xmlschema/#interface"
       xmlns:sensor="http://playerstage.sourceforge.net/gazebo/xmlschema/#sensor"
       xmlns:xacro="http://ros.org/wiki/xacro">

    <!-- common xacro -->
    <xacro:include filename="$(find hsrc_description)/urdf/common.xacro" />
    <xacro:include filename="$(find hsrc_description)/urdf/materials.urdf.xacro" />

    <!-- links and joints -->
    <xacro:include filename="$(find hsrc_description)/urdf/base_v0/base.urdf.xacro" />
    <xacro:include filename="$(find hsrc_description)/urdf/torso_v0/torso.urdf.xacro" />
    <xacro:include filename="$(find hsrc_description)/urdf/head_v0/head.urdf.xacro" />
    <xacro:include filename="$(find hsrc_description)/urdf/arm_v0/arm.urdf.xacro" />
    <xacro:include filename="$(find hsrc_description)/urdf/wrist_v0/wrist.urdf.xacro" />
    <xacro:include filename="$(find hsrc_description)/urdf/hand_v0/hand.urdf.xacro" />

    <xacro:arg name="gazebo_sim" default="False"/>
    <xacro:arg name="rviz_sim" default="False"/>

    <xacro:arg name="personal_name" default=""/>
    <xacro:arg name="ground_truth_xyz_offset" default="0.0\ 0.0\ 0.0"/>
    <xacro:arg name="ground_truth_rpy_offset" default="0.0\ 0.0\ 0.0"/>

    <!-- constant -->
    <xacro:property name="personal_name" value="$(arg personal_name)"/>
    <xacro:property name="robot_name" value="hsrb"/>

    <!-- create robot -->
    <xacro:hsrb_base prefix="base" personal_name="${personal_name}" robot_namespace="${robot_name}" robot_name="${robot_name}"/>

    <xacro:hsrb_torso prefix="torso" parent="base_link" mimic_joint="arm_lift_joint">
        <origin xyz="0.0 0.0 0.762" rpy="0.0 0.0 0.0"/>
    </xacro:hsrb_torso>

    <xacro:hsrb_head prefix="head" parent="torso_lift_link">
        <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
    </xacro:hsrb_head>

    <xacro:hsrb_arm prefix="arm" parent="base_link">
        <origin xyz="0.0 0.0 0.350" rpy="0.0 0.0 0.0"/>
    </xacro:hsrb_arm>

    <xacro:hsrb_wrist prefix="wrist" parent="arm_roll_link" robot_namespace="${robot_name}">
        <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
    </xacro:hsrb_wrist>

    <xacro:hsrb_hand prefix="hand" parent="wrist_roll_link">
        <origin xyz="0.0 0.0 0.155" rpy="0.0 0.0 ${pi}"/>
    </xacro:hsrb_hand>

    <!-- Import ros2_control description -->
    <xacro:if value="${not $(arg gazebo_sim) and not $(arg rviz_sim)}">
      <xacro:include filename="$(find hsrc_description)/urdf/ros2_control.robot.xacro" />
      <xacro:ros2_contorl_robot/>
    </xacro:if>

    <xacro:if value="$(arg gazebo_sim)">
      <xacro:include filename="$(find hsrb_description)/urdf/ros2_control.gazebo.xacro" />
      <xacro:ros2_contorl_gazebo/>
    </xacro:if>

    <xacro:if value="$(arg rviz_sim)">
      <xacro:include filename="$(find hsrb_description)/urdf/ros2_control.rviz.xacro" />
      <xacro:ros2_contorl_rviz/>
    </xacro:if>
</robot>
