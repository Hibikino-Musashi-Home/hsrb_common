<?xml version="1.0" ?>
<robot xmlns:xacro="http://ros.org/wiki/xacro" name="hsrc_ex">

    <xacro:property name="Gemini336LWidth" value="0.124"/>
    <xacro:property name="Gemini336LHeight" value="0.029"/>
    <xacro:property name="Gemini336LDepth" value="0.0277"/>

    <xacro:property name="Gemini336LMass" value="0.135"/>

    <xacro:property name="Gemini336LImageWidth" value="640"/>
    <xacro:property name="Gemini336LImageHeight" value="480"/>
    <xacro:property name="Gemini336LMinDistance" value="0.17"/>
    <xacro:property name="Gemini336LMaxDistance" value="20.0"/>
    <xacro:property name="Gemini336LFrameRate" value="30"/>
    <xacro:property name="Gemini336LHorizontalFov" value="1.5708"/>

    <xacro:macro name="gemini_336l_gazebo" params="robot_namespace sensor_name parent_frame topic_frame_id">
        <gazebo reference="${parent_frame}">
            <sensor type="camera" name="${sensor_name}_camera">
                <always_on>0</always_on>
                <update_rate>${Gemini336LFrameRate}</update_rate>
                <visualize>true</visualize>
                <camera>
                    <horizontal_fov>${Gemini336LHorizontalFov}</horizontal_fov>
                    <image>
                        <width>${Gemini336LImageWidth}</width>
                        <height>${Gemini336LImageHeight}</height>
                        <format>B8G8R8</format>
                    </image>
                    <depth_camera>
                    </depth_camera>
                    <clip>
                        <near>${Gemini336LMinDistance}</near>
                        <far>${Gemini336LMaxDistance}</far>
                    </clip>
                </camera>
                <plugin name="${sensor_name}_controller" filename="libgazebo_ros_camera.so">
                    <camera_name>${sensor_name}</camera_name>
                    <frame_name>${topic_frame_id}</frame_name>
                    <hack_baseline>0</hack_baseline>
                    <min_depth>${Gemini336LMinDistance}</min_depth>
                    <max_depth>${Gemini336LMaxDistance}</max_depth>
                    <cx>0.0</cx>
                    <cy>0.0</cy>
                    <ros>
                        <namespace>${robot_namespace}</namespace>
                        <remapping>${sensor_name}/image_raw:=${sensor_name}/color/image_rect_color</remapping>
                        <remapping>${sensor_name}/camera_info:=${sensor_name}/color/camera_info</remapping>
                        <remapping>${sensor_name}/depth/image_raw:=${sensor_name}/depth/image_rect_raw</remapping>
                        <remapping>${sensor_name}/depth/camera_info:=${sensor_name}/depth/camera_info</remapping>
                        <remapping>${sensor_name}/points:=${sensor_name}/depth/points</remapping>
                    </ros>
                </plugin>
            </sensor>
        </gazebo>
    </xacro:macro>

    <xacro:macro name="gemini_336l_gazebo_ignition" params="robot_namespace sensor_name parent_frame topic_frame_id">
        <gazebo reference="${parent_frame}">
            <sensor type="camera" name="${sensor_name}_camera_rgb">
                <always_on>0</always_on>
                <update_rate>${Gemini336LFrameRate}</update_rate>
                <visualize>true</visualize>
                <camera>
                    <horizontal_fov>${Gemini336LHorizontalFov}</horizontal_fov>
                    <image>
                        <width>${Gemini336LImageWidth}</width>
                        <height>${Gemini336LImageHeight}</height>
                        <format>B8G8R8</format>
                    </image>
                    <clip>
                        <near>0.1</near>
                        <far>100</far>
                    </clip>
                </camera>
                <gz_frame_id>${topic_frame_id}</gz_frame_id>
                <topic>${robot_namespace}/${sensor_name}/color/image_raw</topic>
            </sensor>
            <sensor type="depth_camera" name="${sensor_name}_camera_depth">
                <always_on>0</always_on>
                <update_rate>${Gemini336LFrameRate}</update_rate>
                <visualize>true</visualize>
                <camera>
                    <horizontal_fov>${Gemini336LHorizontalFov}</horizontal_fov>
                    <image>
                        <width>${Gemini336LImageWidth}</width>
                        <height>${Gemini336LImageHeight}</height>
                        <!-- Not working. Float only -->
                        <format>L_INT16</format>
                    </image>
                    <clip>
                        <near>${Gemini336LMinDistance}</near>
                        <far>${Gemini336LMaxDistance}</far>
                    </clip>
                </camera>
                <gz_frame_id>${topic_frame_id}</gz_frame_id>
                <topic>${robot_namespace}/${sensor_name}/depth/image</topic>
            </sensor>
        </gazebo>
    </xacro:macro>
</robot>